---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/utils';
import LocalBusinessJsonLd from '../../components/seo/LocalBusinessJsonLd.astro';
import OrganizationJsonLd from '../../components/seo/OrganizationJsonLd.astro';
import Hero from '../../components/home/Hero.astro';
import CommonQuestions from '../../components/home/CommonQuestions.astro';
import ByTheNumbers from '../../components/home/ByTheNumbers.astro';
import PhilosophyBand from '../../components/home/PhilosophyBand.astro';
import TeamCallout from '../../components/home/TeamCallout.astro';
import WhoWeServe from '../../components/home/WhoWeServe.astro';
import Testimonial from '../../components/home/Testimonial.astro';
import FinalCta from '../../components/home/FinalCta.astro';

const lang = 'ko' as const;
const t = useTranslations(lang);
---

<BaseLayout
  title={t('home.pageTitle')}
  description={t('home.metaDescription')}
  lang={lang}
  path="/"
>
  <LocalBusinessJsonLd lang={lang} />
  <OrganizationJsonLd />

  <Hero lang={lang} />
  <CommonQuestions lang={lang} />
  <ByTheNumbers lang={lang} />
  <PhilosophyBand lang={lang} />
  <TeamCallout lang={lang} />
  <WhoWeServe lang={lang} />
  <Testimonial lang={lang} />
  <FinalCta lang={lang} />
</BaseLayout>

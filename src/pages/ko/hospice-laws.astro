---
import LongFormLayout from '../../layouts/LongFormLayout.astro';
import PageSidebar from '../../components/layout/PageSidebar.astro';
import Icon from '../../components/ui/Icon.astro';
import { localizedPath } from '../../i18n/utils';
import { CONTACT } from '../../data/site-config';
import koData from '../../i18n/ko.json';

const lang = 'ko' as const;
const lp = (p: string) => localizedPath(p, lang);
const d = koData.hospiceLaws;
const s = d.sections;
const common = koData.common;

const anchors = [
  { id: 'cops',        label: '연방 기준' },
  { id: 'rights',      label: '환자 권리' },
  { id: 'directives',  label: '사전 의료 지시서' },
  { id: 'complaints',  label: '불만 신고' },
  { id: 'hipaa',       label: 'HIPAA 및 개인정보' },
];
const relatedLinks = [
  { href: '/understanding-hospice', label: common.relatedPages.links.understandingHospice },
  { href: '/insurance',             label: common.relatedPages.links.insurance },
  { href: '/hipaa-notice',          label: common.relatedPages.links.hipaaNotice },
];
---

<LongFormLayout
  title={d.pageTitle}
  description={d.metaDescription}
  lang={lang}
  path="/hospice-laws"
  eyebrow="호스피스 법률 및 환자 권리"
  introParagraph={d.introParagraph}
  lastReviewed={d.lastReviewed}
>
  <PageSidebar slot="sidebar" {anchors} {relatedLinks} {lang} />

  <section id="cops" class="scroll-mt-24">
    <h2>{s.cops.title}</h2>
    <p>{s.cops.body}</p>
    <p class="not-prose mt-3">
      <a
        href={s.cops.cmsLinkUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1 text-primary-600 hover:text-primary-700 font-medium text-sm
               focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 rounded-sm"
      >
        {s.cops.cmsLinkLabel}
        <Icon name="arrowRight" class="w-4 h-4" />
      </a>
    </p>
  </section>

  <section id="rights" class="scroll-mt-24">
    <h2>{s.patientRights.title}</h2>
    <p>{s.patientRights.intro}</p>
    <ul class="not-prose mt-4 space-y-2">
      {s.patientRights.items.map(item => (
        <li class="flex items-start gap-3">
          <div class="rounded-full bg-primary-100 p-1 flex-shrink-0 mt-1">
            <Icon name="check" class="w-3.5 h-3.5 text-primary-700" />
          </div>
          <span class="text-ink-700 font-prose leading-relaxed text-sm">{item}</span>
        </li>
      ))}
    </ul>
    <p class="not-prose mt-4">
      <a
        href={s.patientRights.linkUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1 text-primary-600 hover:text-primary-700 font-medium text-sm
               focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 rounded-sm"
      >
        {s.patientRights.linkLabel}
        <Icon name="arrowRight" class="w-4 h-4" />
      </a>
    </p>
  </section>

  <section id="directives" class="scroll-mt-24">
    <h2>{s.advanceDirectives.title}</h2>
    <p>{s.advanceDirectives.intro}</p>

    <h3>{s.advanceDirectives.livingWill.title}</h3>
    <p>{s.advanceDirectives.livingWill.body}</p>
    <div class="not-prose mt-2 rounded-card border-l-4 border-primary-300 bg-primary-50 px-5 py-3">
      <p class="text-sm text-ink-700">{s.advanceDirectives.livingWill.caLawNote}</p>
    </div>

    <h3>{s.advanceDirectives.polst.title}</h3>
    <p>{s.advanceDirectives.polst.body}</p>
    <div class="not-prose mt-2 rounded-card border-l-4 border-amber-400 bg-amber-50 px-5 py-3">
      <p class="text-sm text-ink-700">{s.advanceDirectives.polst.paperColorNote}</p>
    </div>

    <h3>{s.advanceDirectives.dpoa.title}</h3>
    <p>{s.advanceDirectives.dpoa.body}</p>
  </section>

  <section id="complaints" class="scroll-mt-24">
    <h2>{s.complaints.title}</h2>
    <p>{s.complaints.intro}</p>

    <div class="not-prose mt-5 space-y-4">
      {Object.entries(s.complaints.paths).map(([, path]) => (
        <div class="rounded-card border border-line-soft bg-white p-5 shadow-soft">
          <h3 class="font-heading text-base text-ink-900 mb-1">{path.name}</h3>
          <p class="text-sm text-ink-600 leading-relaxed">{path.contact}</p>
        </div>
      ))}
    </div>

    <div class="not-prose mt-4 rounded-card border-l-4 border-primary-300 bg-primary-50 px-5 py-3">
      <p class="text-sm text-ink-700">{s.complaints.retaliationProtection}</p>
    </div>
  </section>

  <section id="hipaa" class="scroll-mt-24">
    <h2>{s.hipaa.title}</h2>
    <p>{s.hipaa.body}</p>
    <p class="not-prose mt-3 text-sm text-ink-500 italic">{s.hipaa.noticeLabel}</p>
    <p class="not-prose mt-3">
      <a
        href={lp('/hipaa-notice')}
        class="inline-flex items-center gap-1 text-primary-600 hover:text-primary-700 font-medium text-sm
               focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 rounded-sm"
      >
        {common.relatedPages.links.hipaaNotice}
        <Icon name="arrowRight" class="w-4 h-4" />
      </a>
    </p>
  </section>
</LongFormLayout>

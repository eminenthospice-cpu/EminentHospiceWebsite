---
import LongFormLayout from '../../layouts/LongFormLayout.astro';
import PageSidebar from '../../components/layout/PageSidebar.astro';
import Icon from '../../components/ui/Icon.astro';
import { localizedPath } from '../../i18n/utils';
import { CONTACT } from '../../data/site-config';
import enData from '../../i18n/en.json';

const lang = 'en' as const;
const lp = (p: string) => localizedPath(p, lang);
const d = enData.insurance;
const s = d.sections;
const common = enData.common;

const levelOrder = ['rhc', 'chc', 'gip', 'irc'] as const;

const anchors = [
  { id: 'cost',     label: 'What Does It Cost?' },
  { id: 'medicare', label: 'Medicare Part A' },
  { id: 'levels',   label: 'Four Levels of Care' },
  { id: 'medical',  label: 'Medi-Cal Coverage' },
  { id: 'compare',  label: 'Coverage Comparison' },
  { id: 'election', label: 'Election Process' },
  { id: 'help',     label: 'Verify Coverage' },
];
const relatedLinks = [
  { href: '/understanding-hospice', label: common.relatedPages.links.understandingHospice },
  { href: '/hospice-laws',          label: common.relatedPages.links.hospiceLaws },
  { href: '/faq',                   label: common.relatedPages.links.faq },
  { href: '/contact',               label: common.relatedPages.links.contact },
];
---

<LongFormLayout
  title={d.pageTitle}
  description={d.metaDescription}
  lang={lang}
  path="/insurance"
  eyebrow="Insurance & Medicare"
  introParagraph={d.introParagraph}
  lastReviewed={d.lastReviewed}
>
  <PageSidebar slot="sidebar" {anchors} {relatedLinks} {lang} />

  <section id="cost" class="scroll-mt-24">
    <h2>{s.cost.title}</h2>
    <p>{s.cost.p1}</p>
    <div class="not-prose mt-3 rounded-card border-l-4 border-primary-300 bg-primary-50 px-5 py-3">
      <p class="text-sm text-ink-700">{s.cost.footnote}</p>
    </div>
  </section>

  <section id="medicare" class="scroll-mt-24">
    <h2>{s.medicare.title}</h2>
    <div class="not-prose mt-4 space-y-4">
      {([
        { label: lang === 'ko' ? '자격 요건' : 'Eligibility',  body: s.medicare.eligibility },
        { label: lang === 'ko' ? '포함 항목' : 'Covered',      body: s.medicare.covered },
        { label: lang === 'ko' ? '미포함 항목' : 'Not covered', body: s.medicare.notCovered },
      ]).map(item => (
        <div class="rounded-card border border-line-soft bg-white p-5 shadow-soft">
          <p class="eyebrow text-primary-600 mb-1">{item.label}</p>
          <p class="text-sm text-ink-700 leading-relaxed font-prose">{item.body}</p>
        </div>
      ))}
    </div>
  </section>

  <section id="levels" class="scroll-mt-24">
    <h2>{s.levels.title}</h2>
    <p>{s.levels.intro}</p>
    <div class="not-prose mt-4 space-y-4">
      {levelOrder.map(key => {
        const level = s.levels[key];
        return (
          <div class="rounded-card border border-line-soft bg-white p-5 shadow-soft">
            <h3 class="font-heading text-base text-ink-900 mb-1">{level.name}</h3>
            <p class="text-sm text-ink-600 leading-relaxed mb-2">{level.desc}</p>
            <p class="text-xs text-ink-400 italic">{level.rateNote}</p>
          </div>
        );
      })}
    </div>
    <div class="not-prose mt-4 rounded-card border border-line-soft bg-surface-paper p-5">
      <div class="flex justify-between flex-wrap gap-2 mb-3">
        <span class="font-heading text-sm font-semibold text-ink-900">{s.levels.aggregateCap.label}</span>
        <span class="font-heading text-sm font-semibold text-primary-700">{s.levels.aggregateCap.value}</span>
      </div>
      <p class="text-xs text-ink-500">{s.levels.aggregateCap.desc}</p>
      <p class="text-xs text-ink-400 mt-2 italic">{s.levels.sourceNote}</p>
    </div>
    <p class="not-prose mt-2 text-xs text-ink-400 italic">{s.levels.fy2026Note}</p>
  </section>

  <section id="medical" class="scroll-mt-24">
    <h2>{s.medical.title}</h2>
    <p>{s.medical.body}</p>
    <div class="not-prose mt-3 rounded-card border-l-4 border-primary-300 bg-primary-50 px-5 py-3">
      <p class="text-sm text-ink-700">{s.medical.roomAndBoardNote}</p>
    </div>
  </section>

  <section id="compare" class="scroll-mt-24">
    <h2>{s.comparison.headers.service} — {lang === 'ko' ? '비교' : 'Comparison'}</h2>
    <p>{s.comparison.intro}</p>
    <div class="not-prose mt-4 overflow-x-auto">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="bg-surface-paper">
            <th class="text-left px-4 py-3 font-heading text-ink-700 border border-line-soft">{s.comparison.headers.service}</th>
            <th class="text-left px-4 py-3 font-heading text-ink-700 border border-line-soft">{s.comparison.headers.medicare}</th>
            <th class="text-left px-4 py-3 font-heading text-ink-700 border border-line-soft">{s.comparison.headers.medical}</th>
            <th class="text-left px-4 py-3 font-heading text-ink-700 border border-line-soft">{s.comparison.headers.private}</th>
          </tr>
        </thead>
        <tbody>
          {Object.values(s.comparison.rows).map((row, i) => (
            <tr class={i % 2 === 0 ? 'bg-white' : 'bg-surface-paper'}>
              <td class="px-4 py-3 font-medium text-ink-800 border border-line-soft">{row.label}</td>
              <td class="px-4 py-3 text-ink-600 border border-line-soft">{row.medicare}</td>
              <td class="px-4 py-3 text-ink-600 border border-line-soft">{row.medical}</td>
              <td class="px-4 py-3 text-ink-600 border border-line-soft">{row.private}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section id="election" class="scroll-mt-24">
    <h2>{s.election.title}</h2>
    <p>{s.election.intro}</p>
    <ol class="not-prose mt-4 space-y-3">
      {s.election.steps.map((step, i) => (
        <li class="flex items-start gap-4">
          <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-primary-500 text-white text-xs font-bold flex-shrink-0 mt-0.5">
            {i + 1}
          </span>
          <span class="text-ink-700 font-prose text-sm leading-relaxed">{step}</span>
        </li>
      ))}
    </ol>
    <div class="not-prose mt-4 rounded-card border-l-4 border-primary-300 bg-primary-50 px-5 py-3">
      <p class="text-sm text-ink-700">{s.election.revocationNote}</p>
    </div>
  </section>

  <section id="help" class="scroll-mt-24">
    <h2>{s.help.title}</h2>
    <p>{s.help.body}</p>
    <div class="not-prose mt-5">
      <a
        href={lp('/contact')}
        class="inline-flex items-center justify-center gap-2 min-h-[44px] px-6 py-3
               rounded-btn bg-primary-500 text-white font-medium hover:bg-primary-600
               transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2
               focus-visible:ring-primary-500 focus-visible:ring-offset-2"
      >
        {s.help.ctaLabel}
        <Icon name="arrowRight" class="w-4 h-4" />
      </a>
    </div>
  </section>
</LongFormLayout>

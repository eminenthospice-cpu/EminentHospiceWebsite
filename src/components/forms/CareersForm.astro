---
import { FORMS, CONTACT } from '../../data/site-config';
import { useTranslations } from '../../i18n/utils';

export interface Props {
  lang: 'en' | 'ko';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const positionKeys = ['rn', 'lvn', 'aide', 'msw', 'chaplain', 'bereavement', 'volunteer', 'admin', 'other'] as const;
const endpoint = FORMS.careersEndpoint;
const phoneDisplay = CONTACT.phone.display;
---

<div id="careers-form-wrapper">
  <div id="careers-success" class="hidden p-6 text-center" role="status" aria-live="polite">
    <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-primary-50 mb-4">
      <svg class="w-8 h-8 text-primary-600" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
      </svg>
    </div>
    <h3 class="font-heading text-xl text-ink-900 mb-2">{t('careers.success.title')}</h3>
    <p class="text-ink-600 leading-relaxed font-prose">{t('careers.success.body')}</p>
  </div>

  <form
    id="careers-form"
    action={endpoint}
    method="POST"
    novalidate
    class="space-y-5"
  >
    <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />

    <div id="careers-error" class="hidden rounded-card bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700" role="alert"></div>

    <h2 class="font-heading text-2xl text-ink-900">{t('careers.form.heading')}</h2>
    <p class="font-prose text-ink-600">{t('careers.form.intro')}</p>

    <div class="grid sm:grid-cols-2 gap-5">
      <div>
        <label for="c-name" class="block text-sm font-medium text-ink-700 mb-1">
          {t('careers.form.nameLabel')} <span class="text-red-500" aria-hidden="true">*</span>
        </label>
        <input
          id="c-name"
          name="name"
          type="text"
          autocomplete="name"
          required
          placeholder={t('careers.form.namePlaceholder')}
          class="w-full rounded-input border border-line-soft px-4 py-2.5 text-ink-900 placeholder-ink-400
                 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500
                 transition-colors duration-100"
        />
      </div>

      <div>
        <label for="c-email" class="block text-sm font-medium text-ink-700 mb-1">
          {t('careers.form.emailLabel')} <span class="text-red-500" aria-hidden="true">*</span>
        </label>
        <input
          id="c-email"
          name="email"
          type="email"
          autocomplete="email"
          required
          placeholder={t('careers.form.emailPlaceholder')}
          class="w-full rounded-input border border-line-soft px-4 py-2.5 text-ink-900 placeholder-ink-400
                 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500
                 transition-colors duration-100"
        />
      </div>
    </div>

    <div class="grid sm:grid-cols-2 gap-5">
      <div>
        <label for="c-phone" class="block text-sm font-medium text-ink-700 mb-1">
          {t('careers.form.phoneLabel')}
        </label>
        <input
          id="c-phone"
          name="phone"
          type="tel"
          autocomplete="tel"
          placeholder={t('careers.form.phonePlaceholder')}
          class="w-full rounded-input border border-line-soft px-4 py-2.5 text-ink-900 placeholder-ink-400
                 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500
                 transition-colors duration-100"
        />
      </div>

      <div>
        <label for="c-position" class="block text-sm font-medium text-ink-700 mb-1">
          {t('careers.form.positionLabel')}
        </label>
        <select
          id="c-position"
          name="position"
          class="w-full rounded-input border border-line-soft px-4 py-2.5 text-ink-900
                 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500
                 transition-colors duration-100 bg-white"
        >
          {positionKeys.map(key => (
            <option value={key}>{t(`careers.form.positionOptions.${key}` as any)}</option>
          ))}
        </select>
      </div>
    </div>

    <div>
      <label for="c-message" class="block text-sm font-medium text-ink-700 mb-1">
        {t('careers.form.messageLabel')} <span class="text-red-500" aria-hidden="true">*</span>
      </label>
      <textarea
        id="c-message"
        name="message"
        rows="5"
        required
        placeholder={t('careers.form.messagePlaceholder')}
        class="w-full rounded-input border border-line-soft px-4 py-2.5 text-ink-900 placeholder-ink-400
               focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500
               transition-colors duration-100 resize-y"
      ></textarea>
    </div>

    <div class="flex items-center justify-between gap-4 flex-wrap">
      <button
        id="careers-submit"
        type="submit"
        class="inline-flex items-center justify-center gap-2 min-h-[44px] px-6 py-3
               rounded-btn bg-primary-500 text-white font-medium hover:bg-primary-600
               transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2
               focus-visible:ring-primary-500 focus-visible:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed"
      >
        <span id="careers-submit-label">{t('careers.form.submitLabel')}</span>
      </button>
      <p class="text-xs text-ink-400 font-prose max-w-xs">{t('careers.form.privacyNote')}</p>
    </div>
  </form>
</div>

<script define:vars={{ endpoint, phoneDisplay, lang }}>
  const form = document.getElementById('careers-form');
  const successDiv = document.getElementById('careers-success');
  const errorDiv = document.getElementById('careers-error');
  const submitBtn = document.getElementById('careers-submit');
  const submitLabel = document.getElementById('careers-submit-label');

  const pendingLabel = form?.querySelector('[data-pending]')?.textContent
    || (lang === 'ko' ? '전송 중…' : 'Sending…');

  const msgs = {
    required: lang === 'ko' ? '필수 항목입니다.' : 'This field is required.',
    invalidEmail: lang === 'ko' ? '유효한 이메일 주소를 입력해 주세요.' : 'Please enter a valid email address.',
    tooShort: lang === 'ko' ? '조금 더 자세히 작성해 주세요.' : 'Please add a little more detail.',
    serverError: lang === 'ko'
      ? `문제가 발생했습니다. ${phoneDisplay}로 전화해 주세요.`
      : `Something went wrong. Please call us at ${phoneDisplay}.`,
  };

  function showError(msg) {
    if (!errorDiv) return;
    errorDiv.textContent = msg;
    errorDiv.classList.remove('hidden');
    errorDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function clearError() {
    if (errorDiv) errorDiv.classList.add('hidden');
  }

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      clearError();

      const nameVal = form.querySelector('#c-name')?.value.trim() ?? '';
      const emailVal = form.querySelector('#c-email')?.value.trim() ?? '';
      const messageVal = form.querySelector('#c-message')?.value.trim() ?? '';

      if (!nameVal) { showError(msgs.required); return; }
      if (!emailVal || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailVal)) { showError(msgs.invalidEmail); return; }
      if (messageVal.length < 10) { showError(msgs.tooShort); return; }

      if (submitBtn) submitBtn.setAttribute('disabled', '');
      if (submitLabel) {
        submitLabel.textContent = lang === 'ko' ? '전송 중…' : 'Sending…';
      }

      try {
        const res = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Accept': 'application/json' },
          body: new FormData(form),
        });

        if (res.ok) {
          form.classList.add('hidden');
          successDiv?.classList.remove('hidden');
        } else {
          const json = await res.json().catch(() => ({}));
          showError(json?.errors?.[0]?.message ?? msgs.serverError);
          if (submitBtn) submitBtn.removeAttribute('disabled');
          if (submitLabel) {
            submitLabel.textContent = lang === 'ko' ? '지원서 보내기' : 'Send application';
          }
        }
      } catch {
        showError(msgs.serverError);
        if (submitBtn) submitBtn.removeAttribute('disabled');
        if (submitLabel) {
          submitLabel.textContent = lang === 'ko' ? '지원서 보내기' : 'Send application';
        }
      }
    });
  }
</script>

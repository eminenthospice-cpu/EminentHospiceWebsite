---
export interface Props {
  value: string;
  label: string;
  align?: 'left' | 'center';
  class?: string;
}

const { value, label, align = 'left', class: className = '' } = Astro.props;

const classes = [
  'flex flex-col',
  align === 'center' ? 'items-center text-center' : '',
  className,
].join(' ');
---

<div class={classes}>
  <div class="rule-hair w-full mb-4" aria-hidden="true"></div>
  <p class="numeral-wall">{value}</p>
  <p class="mt-3 marginalia text-ink-700 tracking-wide">{label}</p>
</div>

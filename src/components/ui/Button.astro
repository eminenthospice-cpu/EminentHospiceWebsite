---
/**
 * Button.astro — variant-driven button primitive.
 * Variants: primary | secondary | ghost | cta | gold | warm | link
 * Sizes: sm | md | lg | xl
 *
 * `gold` is the conversion variant (referral, phone) — gold fill, ink text
 * for AA contrast. `warm` is a deprecated alias kept on the same gold style
 * so existing usages migrate without breaking.
 */
export interface Props {
  variant?: 'primary' | 'secondary' | 'ghost' | 'cta' | 'gold' | 'warm' | 'link';
  size?: 'sm' | 'md' | 'lg' | 'xl';
  href?: string;
  class?: string;
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
  [key: string]: unknown;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  class: className = '',
  type = 'button',
  disabled,
  ...rest
} = Astro.props;

const base =
  'inline-flex items-center justify-center gap-2 font-body font-medium rounded-btn press-tap ' +
  'transition-[transform,background-color,box-shadow,color] duration-150 ease-snap ' +
  'active:scale-[0.985] active:duration-[80ms] ' +
  'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2 ' +
  'focus-visible:ring-offset-surface-paper disabled:pointer-events-none disabled:opacity-50 select-none whitespace-nowrap';

const variants: Record<string, string> = {
  primary:   'bg-primary-500 text-white shadow-card hover:bg-primary-600 active:bg-primary-700',
  secondary: 'border-2 border-primary-500 text-primary-600 bg-transparent hover:bg-primary-50 active:bg-primary-100',
  ghost:     'text-ink-700 hover:text-primary-600 hover:bg-primary-50 active:bg-primary-100',
  cta:       'bg-primary-600 text-white shadow-card hover:bg-primary-700 active:bg-primary-800 shadow-[0_8px_24px_-8px_rgba(15,47,70,0.35)]',
  gold:      'bg-accent-gold-500 text-ink-900 shadow-card hover:bg-accent-gold-400 active:bg-accent-gold-600',
  warm:      'bg-accent-gold-500 text-ink-900 shadow-card hover:bg-accent-gold-400 active:bg-accent-gold-600',
  link:      'text-primary-600 underline-offset-4 hover:underline px-0 py-0',
};

// Touch-safe floor: every interactive size meets the 44px minimum the
// accessibility statement claims. `sm` is retained for tight chrome only.
const sizes: Record<string, string> = {
  sm: 'h-11 px-4 text-body-sm min-h-[44px]',
  md: 'h-11 px-5 text-base min-h-[44px]',
  lg: 'h-12 px-6 text-base min-h-[48px]',
  xl: 'h-14 px-8 text-lg min-h-[56px]',
};

const classes = [base, variants[variant], sizes[size], className].join(' ');
const Tag = href ? 'a' : 'button';
---

{href ? (
  <a href={href} class={classes} {...rest}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} disabled={disabled} {...rest}>
    <slot />
  </button>
)}

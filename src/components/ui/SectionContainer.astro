---
/**
 * SectionContainer.astro — Wraps a <section> with consistent
 * max-width, padding, and background tokens.
 */
export interface Props {
  id?: string;
  bg?: 'warm' | 'cream' | 'white' | 'primary';
  class?: string;
  innerClass?: string;
  ariaLabelledBy?: string;
  ariaLabel?: string;
}

const {
  id,
  bg = 'white',
  class: className = '',
  innerClass = '',
  ariaLabelledBy,
  ariaLabel,
} = Astro.props;

const bgClasses: Record<string, string> = {
  warm:    'bg-neutral-warm',
  cream:   'bg-neutral-cream',
  white:   'bg-white',
  primary: 'bg-primary-900 text-white',
};

const sectionClass = [bgClasses[bg], className].join(' ').trim();
---

<section
  id={id}
  aria-labelledby={ariaLabelledBy}
  aria-label={ariaLabel}
  class={sectionClass}
>
  <div class={`max-w-[90rem] mx-auto min-w-0 px-6 md:px-12 lg:px-16 py-20 lg:py-26 ${innerClass}`.trim()}>
    <slot />
  </div>
</section>

---
/**
 * Accordion.astro — Pure CSS accordion using <details>/<summary>.
 * No JS required. Accessible, animated with CSS.
 *
 * Usage:
 *   <Accordion items={[{ title: '...', body: '...' }]} />
 */
export interface AccordionItem {
  title: string;
  body: string;
  open?: boolean;
}

export interface Props {
  items: AccordionItem[];
  class?: string;
}

const { items, class: className = '' } = Astro.props;
---

<div class={`divide-y divide-line-soft border-t border-line-soft ${className}`}>
  {items.map((item) => (
    <details class="group" open={item.open}>
      <summary class="flex items-center justify-between gap-4 py-5 cursor-pointer list-none min-h-[56px]
        font-heading text-xl text-ink-900 hover:text-primary-700 transition-colors duration-150
        focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 rounded-sm">
        <span>{item.title}</span>
        <svg
          aria-hidden="true"
          class="h-5 w-5 shrink-0 text-ink-500 transition-transform duration-200 group-open:rotate-180"
          fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="m19 9-7 7-7-7" />
        </svg>
      </summary>
      <div class="pb-6 font-prose text-base text-ink-700 leading-relaxed">
        {item.body}
      </div>
    </details>
  ))}
</div>

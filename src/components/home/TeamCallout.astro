---
import { useTranslations } from '../../i18n/utils';
import SectionContainer from '../ui/SectionContainer.astro';

export interface Props {
  lang: 'en' | 'ko';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const eyebrow = lang === 'ko' ? '학제간 팀' : 'Interdisciplinary team';

const roles = [
  'physician', 'rn', 'lvn', 'msw',
  'chaplain', 'aide', 'bereavement', 'volunteer',
] as const;
---

<SectionContainer bg="warm" ariaLabelledBy="team-heading" class="bg-gradient-to-b from-neutral-warm to-neutral-cream">
  <div class="reveal">
    <div class="max-w-prose-wide mb-14 lg:mb-16">
      <p class="eyebrow mb-4">{eyebrow}</p>
      <div class="flex flex-wrap items-baseline gap-x-4 gap-y-2 mb-4 min-w-0">
        <span class="font-heading text-6xl md:text-7xl text-accent-sage-400 leading-none shrink-0" aria-hidden="true">&amp;</span>
        <h2 id="team-heading" class="font-heading text-4xl md:text-5xl text-ink-900 min-w-0 flex-1 leading-tight">
          {t('home.team.title')}
        </h2>
      </div>
      <p class="lead">{t('home.team.intro')}</p>
    </div>
  </div>

  <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-10">
    {roles.map((key) => (
      <li class="py-5 border-b border-line-soft">
        <p class="eyebrow text-ink-500 mb-2">{t(`home.team.roles.${key}.name`)}</p>
        <p class="font-prose text-base text-ink-700 leading-relaxed">
          {t(`home.team.roles.${key}.desc`)}
        </p>
      </li>
    ))}
  </ul>
</SectionContainer>

---
import { useTranslations } from '../../i18n/utils';
import SectionContainer from '../ui/SectionContainer.astro';
import Marginalia from '../ui/Marginalia.astro';
import EditorialFigure from '../ui/EditorialFigure.astro';

export interface Props {
  lang: 'en' | 'ko';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const eyebrow = lang === 'ko' ? '우리의 철학' : 'Our Philosophy';
---

<SectionContainer
  bg="cream"
  ariaLabelledBy="philosophy-heading"
  class="bg-surface-canvas overflow-x-clip"
>
  <div class="rule-hair mb-12 md:mb-16" aria-hidden="true"></div>

  <div class="grid grid-cols-1 min-w-0 lg:grid-cols-12 gap-10 lg:gap-12">
    <div class="lg:col-span-7 min-w-0">
      <div class="reveal">
        <p class="eyebrow mb-5">{eyebrow}</p>
        <h2
          id="philosophy-heading"
          class="font-heading text-4xl md:text-5xl text-ink-900 mb-8 max-w-full leading-tight"
        >
          {t('home.philosophy.title')}
        </h2>
      </div>

      <div class="reveal [--reveal-delay:80ms]">
        <p class="lead mb-8">{t('home.philosophy.paragraph1')}</p>
      </div>

      <div class="reveal [--reveal-delay:160ms]">
        <p class="font-prose text-lg text-ink-700 leading-relaxed max-w-prose">
          {t('home.philosophy.paragraph2')}
        </p>
      </div>
    </div>

    <div class="lg:col-span-4 lg:col-start-9 flex flex-col gap-10">
      <div class="reveal [--reveal-delay:100ms]">
        <Marginalia sticky>{t('home.philosophy.marginalia')}</Marginalia>
      </div>
      <div class="reveal [--reveal-delay:140ms]">
        <EditorialFigure
          slot="homePhilosophyPortrait"
          aspect="4/5"
          lang={lang}
          bleed="right"
          sizes="(min-width: 1024px) 28vw, 85vw"
        />
      </div>
    </div>
  </div>
</SectionContainer>

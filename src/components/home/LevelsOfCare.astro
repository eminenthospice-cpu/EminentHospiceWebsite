---
import { useTranslations, localizedPath } from '../../i18n/utils';
import SectionContainer from '../ui/SectionContainer.astro';
import EditorialFigure from '../ui/EditorialFigure.astro';
import type { ImageSlotKey } from '../../data/images';

export interface Props {
  lang: 'en' | 'ko';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const lp = (p: string) => localizedPath(p, lang);
const eyebrow = lang === 'ko' ? '네 가지 돌봄 단계' : 'Four levels of care';

interface Level { key: string; num: string; slot: ImageSlotKey }
const levels: Level[] = [
  { key: 'routine',    num: '01', slot: 'homeLevelRoutine' },
  { key: 'continuous', num: '02', slot: 'homeLevelContinuous' },
  { key: 'inpatient',  num: '03', slot: 'homeLevelInpatient' },
  { key: 'respite',    num: '04', slot: 'homeLevelRespite' },
];
---

<SectionContainer bg="white" ariaLabelledBy="levels-heading">
  <div class="reveal">
    <div class="max-w-prose-wide mb-14">
      <p class="eyebrow mb-4">{eyebrow}</p>
      <h2 id="levels-heading" class="font-heading text-4xl md:text-5xl text-ink-900 mb-4 leading-tight">
        {t('home.levels.title')}
      </h2>
      <p class="lead">{t('home.levels.subtitle')}</p>
    </div>
  </div>

  <!-- Desktop: two-column layout with border rows -->
  <div class="hidden md:block border-t border-line-soft">
    {levels.map(({ key, num, slot }) => (
      <div class="reveal grid grid-cols-[auto_1fr_auto] gap-8 lg:gap-12 items-start py-10 border-b border-line-soft">
        <span class="font-heading text-3xl tabular-nums text-accent-gold-600 leading-none pt-1 w-12 shrink-0">
          {num}
        </span>
        <div>
          <h3 class="font-heading text-xl text-ink-900 mb-3">{t(`home.levels.${key}.title`)}</h3>
          <p class="font-prose text-base text-ink-700 leading-relaxed max-w-prose">
            {t(`home.levels.${key}.desc`)}
          </p>
          <a
            href={lp('/services')}
            class="underline-grow inline-flex items-center gap-1.5 mt-4 py-2 text-base font-medium text-primary-700 hover:text-primary-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 rounded-sm"
          >
            {t('home.levels.learnMore')}
            <svg aria-hidden="true" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
        <div class="w-48 lg:w-64 shrink-0">
          <EditorialFigure slot={slot} aspect="4/3" lang={lang} sizes="(min-width: 768px) 20vw, 48vw" />
        </div>
      </div>
    ))}
  </div>

  <!-- Mobile: accordion using <details> -->
  <div class="md:hidden border-t border-line-soft">
    {levels.map(({ key, num, slot }, i) => (
      <details class="group border-b border-line-soft" open={i === 0}>
        <summary class="flex items-center gap-4 py-5 cursor-pointer list-none min-h-[64px]
          focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 rounded-sm">
          <span class="font-heading text-xl tabular-nums text-accent-gold-600 w-10 shrink-0">{num}</span>
          <span class="font-heading text-lg text-ink-900 flex-1">{t(`home.levels.${key}.title`)}</span>
          <svg aria-hidden="true" class="h-4 w-4 shrink-0 text-ink-400 transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="m19 9-7 7-7-7" />
          </svg>
        </summary>
        <div class="space-y-5 pb-6">
          <EditorialFigure slot={slot} aspect="4/3" lang={lang} />
          <p class="text-ink-700 leading-relaxed font-prose">{t(`home.levels.${key}.desc`)}</p>
          <a
            href={lp('/services')}
            class="underline-grow inline-flex items-center gap-1.5 text-base font-medium text-primary-700"
          >
            {t('home.levels.learnMore')}
            <svg aria-hidden="true" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
      </details>
    ))}
  </div>
</SectionContainer>

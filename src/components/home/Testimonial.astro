---
import { useTranslations } from '../../i18n/utils';
import SectionContainer from '../ui/SectionContainer.astro';

export interface Props {
  lang: 'en' | 'ko';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<SectionContainer bg="white" ariaLabel={lang === 'ko' ? '가족 후기' : 'Family testimonial'} class="bg-surface-paper">
  <div class="reveal">
    <figure class="max-w-3xl">
      <p class="rule-hair pt-4 eyebrow text-ink-500 mb-6">{t('home.testimonial.provenance')}</p>
      <blockquote class="font-heading italic text-4xl md:text-5xl text-ink-900 leading-snug mb-8 max-w-prose">
        {t('home.testimonial.quote')}
      </blockquote>
      <figcaption class="callout-marginalia max-w-xs">
        <cite class="not-italic eyebrow text-ink-500">
          {t('home.testimonial.attributionName')}
        </cite>
        <p class="mt-1 italic text-ink-700 font-prose text-base">{t('home.testimonial.attributionRelation')}</p>
      </figcaption>
    </figure>
  </div>
</SectionContainer>

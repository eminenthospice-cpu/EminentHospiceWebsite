---
import { useTranslations } from '../../i18n/utils';
import SectionContainer from '../ui/SectionContainer.astro';

export interface Props {
  lang: 'en' | 'ko';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<SectionContainer bg="white" ariaLabel={lang === 'ko' ? '가족 후기' : 'Family testimonial'} class="bg-surface-paper">
  <div class="reveal">
    <figure class="max-w-4xl">
      <p class="rule-hair pt-4 eyebrow text-ink-500 mb-6">{t('home.testimonial.provenance')}</p>
      <blockquote class="font-prose text-[clamp(1.3125rem,calc(0.7vw+0.95rem),1.75rem)] text-ink-900 leading-[1.65] mb-8 max-w-[62ch]">
        {t('home.testimonial.quote')}
      </blockquote>
      <figcaption class="callout-marginalia max-w-sm">
        <cite class="not-italic eyebrow text-ink-500">
          {t('home.testimonial.attributionName')}
        </cite>
        <p class="mt-1 italic text-ink-700 font-prose text-body-sm">{t('home.testimonial.attributionRelation')}</p>
      </figcaption>
    </figure>
  </div>
</SectionContainer>

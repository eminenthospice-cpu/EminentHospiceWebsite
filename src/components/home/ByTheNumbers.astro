---
import { useTranslations } from '../../i18n/utils';
import Stat from '../ui/Stat.astro';

export interface Props {
  lang: 'en' | 'ko';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const stats = ['stat1', 'stat2', 'stat3'] as const;
---

<section
  aria-label={t('home.byTheNumbers.ariaLabel')}
  class="bg-surface-paper border-y border-line-soft"
>
  <div class="max-w-[90rem] mx-auto px-6 md:px-12 lg:px-16 py-10 md:py-12">
    <ul class="grid grid-cols-1 sm:grid-cols-3 sm:divide-x sm:divide-line-soft divide-y sm:divide-y-0 divide-line-soft">
      {stats.map((key, i) => (
        <li class="px-0 sm:px-8 py-8 sm:py-0 first:pt-0 last:pb-0 sm:first:pl-0 sm:last:pr-0">
          <div class={`scale-in [--scale-delay:${i * 80}ms]`}>
            <Stat
              value={t(`home.byTheNumbers.${key}.value`)}
              label={t(`home.byTheNumbers.${key}.label`)}
              valueStyle={key === 'stat2' ? 'text' : 'number'}
              align="center"
              class="sm:items-center sm:text-center"
            />
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

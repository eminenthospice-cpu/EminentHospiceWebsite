---
/**
 * StickyCallBar — a persistent click-to-call bar pinned to the bottom of the
 * viewport on small screens only. The single most important action (call us)
 * is always one tap away for visitors who arrive in a hurry or in crisis.
 *
 * Hidden on lg+ where the header phone number and CTAs are already visible.
 * Adds bottom padding to <body> on mobile (see global.css) so the bar never
 * covers page content or the footer.
 */
import { useTranslations } from '../../i18n/utils';
import { CONTACT } from '../../data/site-config';

export interface Props {
  lang: 'en' | 'ko';
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div
  class="lg:hidden fixed inset-x-0 bottom-0 z-40 border-t"
  style="background: var(--color-surface-ink); border-color: var(--color-line-hairline); padding-bottom: env(safe-area-inset-bottom);"
  data-sticky-call-bar
>
  <a
    href={`tel:${CONTACT.phone.tel}`}
    class="flex items-center justify-center gap-3 px-4 py-3 min-h-[56px] font-semibold press-tap
           focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-accent-gold-300"
    style="color: var(--color-tint-ivory);"
    aria-label={`${t('common.callBar.ariaLabel')} — ${CONTACT.phone.display}`}
  >
    <span class="text-caption opacity-80 hidden sm:inline">{t('common.callBar.label')}</span>
    <span
      class="inline-flex items-center gap-2 rounded-btn px-4 py-2"
      style="background: var(--color-accent-gold-500); color: var(--color-ink-900);"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
        fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
        stroke-linejoin="round" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.2h3a2 2 0 0 1 2 1.72c.127.96.362 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.85a16 16 0 0 0 6.26 6.26l.85-.85a2 2 0 0 1 2.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
      {t('common.callBar.cta')} {CONTACT.phone.display}
    </span>
  </a>
</div>

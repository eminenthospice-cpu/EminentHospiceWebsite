---
import { useTranslations, localizedPath } from '../../i18n/utils';
import { CONTACT } from '../../data/site-config';

export interface Props {
  lang: 'en' | 'ko';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const lp = (p: string) => localizedPath(p, lang);

const careLinks = [
  { label: t('footer.aboutUs'),         href: lp('/about') },
  { label: t('footer.hospiceServices'), href: lp('/services') },
] as const;

const resourceLinks = [
  { label: t('footer.home'),     href: lp('/') },
  { label: t('footer.faq'),      href: lp('/faq') },
  { label: t('footer.contact'),  href: lp('/contact') },
  { label: t('footer.referral'), href: lp('/referral') },
] as const;

const legalLinks = [
  { label: t('footer.legalLinks.privacy'),       href: lp('/privacy') },
  { label: t('footer.legalLinks.hipaaNotice'),   href: lp('/hipaa-notice') },
  { label: t('footer.legalLinks.accessibility'), href: lp('/accessibility') },
  { label: t('footer.legalLinks.terms'),         href: lp('/terms') },
] as const;

const certifications = [
  { label: lang === 'ko' ? '메디케어 인증' : 'Medicare Certified' },
  { label: lang === 'ko' ? '연중무휴 24시간 상담' : '24/7 Care Available' },
  { label: lang === 'ko' ? '이중언어 (영어/한국어)' : 'English & Korean' },
];

const year = new Date().getFullYear();
const copyright = t('footer.copyright').replace('{year}', String(year));
---

<footer class="bg-primary-900 text-white mt-auto">
  <!-- Certification strip -->
  <div class="border-b border-primary-800/60">
    <div class="max-w-[90rem] mx-auto px-6 md:px-12 lg:px-16 py-6">
      <ul class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-sm text-primary-100">
        {certifications.map(({ label }) => (
          <li class="flex items-center justify-center sm:justify-start gap-2.5">
            <span class="inline-block w-1.5 h-1.5 rounded-full bg-accent-sage-300 shrink-0" aria-hidden="true"></span>
            <span class="eyebrow text-primary-100">{label}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="max-w-[90rem] mx-auto px-6 md:px-12 lg:px-16 py-14 lg:py-16">
    <!-- Typographic flourish -->
    <p class="font-heading italic text-5xl lg:text-6xl text-accent-gold-300 mb-10">{t('footer.flourish')}</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12">
      <!-- Brand column -->
      <div class="lg:col-span-1">
        <h2 class="font-heading text-2xl font-semibold text-white tracking-tight">
          Eminent Hospice Care
        </h2>
        <p class="mt-3 text-base text-primary-200 leading-relaxed max-w-xs">
          {t('footer.tagline')}
        </p>
      </div>

      <!-- Care column -->
      <nav aria-label={lang === 'ko' ? '돌봄' : 'Care'}>
        <h3 class="eyebrow text-accent-gold-300 mb-4">{lang === 'ko' ? '돌봄' : 'Care'}</h3>
        <ul class="flex flex-col gap-2.5">
          {careLinks.map(({ label, href }) => (
            <li>
              <a
                href={href}
                class="underline-grow inline-flex items-center min-h-11 text-base text-primary-100 hover:text-white transition-colors duration-150 rounded-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white"
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Resources column -->
      <nav aria-label={lang === 'ko' ? '자료' : 'Resources'}>
        <h3 class="eyebrow text-accent-gold-300 mb-4">{lang === 'ko' ? '자료' : 'Resources'}</h3>
        <ul class="flex flex-col gap-2.5">
          {resourceLinks.map(({ label, href }) => (
            <li>
              <a
                href={href}
                class="underline-grow inline-flex items-center min-h-11 text-base text-primary-100 hover:text-white transition-colors duration-150 rounded-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white"
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Contact column -->
      <div>
        <h3 class="eyebrow text-accent-gold-300 mb-4">{t('footer.contactHeading')}</h3>
        <address class="not-italic text-base text-primary-100 space-y-3">
          <p class="flex items-start gap-2">
            <svg class="h-4 w-4 mt-0.5 text-primary-300 shrink-0" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0z"/>
            </svg>
            <span>{t('footer.address')}</span>
          </p>
          <p class="flex items-start gap-2">
            <svg class="h-4 w-4 mt-0.5 text-primary-300 shrink-0" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 6.75z"/>
            </svg>
            <a
              href={`tel:${CONTACT.phone.tel}`}
              class="underline-grow hover:text-white transition-colors duration-150 rounded-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white"
            >
              {t('footer.phone')}
            </a>
          </p>
          <p class="flex items-start gap-2">
            <svg class="h-4 w-4 mt-0.5 text-primary-300 shrink-0" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/>
            </svg>
            <a
              href={`mailto:${CONTACT.email}`}
              class="underline-grow hover:text-white transition-colors duration-150 rounded-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white break-all"
            >
              {t('footer.email')}
            </a>
          </p>
          <p class="text-primary-300 text-caption pt-1">{t('footer.hours')}</p>
        </address>
      </div>
    </div>

    <!-- Legal row -->
    <div class="mt-12 pt-6 border-t border-primary-800/60 space-y-4">
      <nav aria-label={t('footer.legalLinksHeading')}>
        <ul class="flex flex-wrap items-center gap-x-5 gap-y-2 text-caption text-primary-300">
          {legalLinks.map(({ label, href }) => (
            <li>
              <a
                href={href}
                class="underline-grow hover:text-white transition-colors duration-150 rounded-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white"
              >
                {label}
              </a>
            </li>
          ))}
          <li>
            <a
              href="/sitemap-index.xml"
              class="underline-grow hover:text-white transition-colors duration-150 rounded-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white"
            >
              {t('footer.legalLinks.sitemap') || 'Sitemap'}
            </a>
          </li>
        </ul>
      </nav>
      <div class="flex flex-col sm:flex-row justify-between items-center gap-3 text-caption text-primary-400">
        <p>{copyright}</p>
        <p>{t('footer.licensedInCalifornia')}</p>
      </div>
    </div>
  </div>
</footer>

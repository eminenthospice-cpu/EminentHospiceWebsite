---
/**
 * PageSidebar.astro — Sticky TOC + related-page links for content pages.
 */
import { localizedPath } from '../../i18n/utils';

export interface Anchor {
  id: string;
  label: string;
}

export interface RelatedLink {
  href: string;
  label: string;
}

export interface Props {
  anchors: Anchor[];
  relatedLinks?: RelatedLink[];
  lang: 'en' | 'ko';
}

const { anchors, relatedLinks = [], lang } = Astro.props;
const onThisPage = lang === 'ko' ? '이 페이지에서' : 'On this page';
const relatedTitle = lang === 'ko' ? '관련 페이지' : 'Related pages';
---

<nav aria-label={onThisPage} class="sticky top-24 space-y-8">
  <!-- TOC -->
  <div>
    <p class="eyebrow text-ink-400 mb-3">{onThisPage}</p>
    <ul class="space-y-1">
      {anchors.map(({ id, label }) => (
        <li>
          <a
            href={`#${id}`}
            class="block text-sm text-ink-600 hover:text-primary-600 py-1 leading-snug
                   border-l-2 border-transparent pl-3 hover:border-primary-400
                   transition-colors duration-100 focus-visible:outline-none
                   focus-visible:ring-2 focus-visible:ring-primary-500 rounded-sm"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>

  <!-- Related links -->
  {relatedLinks.length > 0 && (
    <div>
      <p class="eyebrow text-ink-400 mb-3">{relatedTitle}</p>
      <ul class="space-y-1">
        {relatedLinks.map(({ href, label }) => (
          <li>
            <a
              href={localizedPath(href, lang)}
              class="block text-sm text-ink-600 hover:text-primary-600 py-1 leading-snug
                     focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 rounded-sm"
            >
              {label} →
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}
</nav>

---
/**
 * AreasIndex — the /hospice-care landing page listing every city we serve.
 * Acts as the hub that links out to each city page (good for crawlability and
 * internal linking) and gives visitors a quick way to find their area.
 */
import LongFormLayout from '../../layouts/LongFormLayout.astro';
import LocalBusinessJsonLd from '../seo/LocalBusinessJsonLd.astro';
import { useTranslations, localizedPath } from '../../i18n/utils';
import { CONTACT } from '../../data/site-config';
import { SERVICE_AREAS } from '../../data/service-areas';

export interface Props {
  lang: 'en' | 'ko';
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const lp = (p: string) => localizedPath(p, lang);

const base = 'serviceAreas.index';
const intro = t(`${base}.intro`).replaceAll('{phone}', CONTACT.phone.display);
const ctaText = t(`${base}.ctaText`).replaceAll('{phone}', CONTACT.phone.display);
---

<LongFormLayout
  title={t(`${base}.pageTitle`)}
  description={t(`${base}.metaDescription`)}
  lang={lang}
  path="/hospice-care"
  eyebrow={t(`${base}.eyebrow`)}
  introParagraph={intro}
>
  <LocalBusinessJsonLd slot="head" lang={lang} />

  <section aria-labelledby="cities-h">
    <h2 id="cities-h">{t(`${base}.listHeading`)}</h2>
    <ul class="not-prose grid grid-cols-1 sm:grid-cols-2 gap-3">
      {SERVICE_AREAS.map((a) => (
        <li>
          <a
            href={lp(`/hospice-care/${a.slug}`)}
            class="group flex items-center justify-between gap-3 rounded-card border border-line-soft bg-white px-5 py-4 shadow-soft
                   hover:border-primary-300 hover:shadow-float transition-all duration-150
                   focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2"
          >
            <span class="font-heading text-lg text-ink-900">{a.name[lang]}</span>
            <span class="text-primary-500 group-hover:translate-x-0.5 transition-transform" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ul>

    <p class="mt-8">{ctaText}</p>
    <p class="not-prose">
      <a
        href={`tel:${CONTACT.phone.tel}`}
        class="inline-flex items-center justify-center gap-2 min-h-[52px] px-7 py-3 rounded-btn font-semibold shadow-soft
               transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2"
        style="background: var(--color-accent-gold-500); color: var(--color-ink-900);"
      >
        <svg aria-hidden="true" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 6.75z" />
        </svg>
        {CONTACT.phone.display}
      </a>
    </p>
  </section>
</LongFormLayout>

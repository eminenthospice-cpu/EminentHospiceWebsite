# Copy to .env.local and fill in real values. Do NOT commit .env.local.

# --- Email vendor (Resend) ---
# Sign up at https://resend.com and add a domain.
RESEND_API_KEY=
# Verified sender on your Resend domain. Used as the From: address.
RESEND_FROM_EMAIL=Eminent Hospice <no-reply@eminenthospice.com>
# Inbox that receives contact-form submissions.
CONTACT_TO_EMAIL=info@eminenthospice.com
# Inbox that receives referral submissions. May equal CONTACT_TO_EMAIL.
REFERRAL_TO_EMAIL=referrals@eminenthospice.com

# --- HIPAA gate ---
# Flip to "true" ONLY after a Business Associate Agreement (BAA) is signed
# with the email vendor. When false, the Referral page renders Mode A
# (phone-first + non-PHI callback form) and the API rejects PHI bodies.
HAS_BAA=false

# --- Cloudflare Turnstile (bot protection) ---
# Get keys at https://dash.cloudflare.com/?to=/:account/turnstile.
# Site key is exposed to the browser; secret stays server-only.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- PHI retention (days) ---
# Displayed in the Mode B privacy notice and used by ops to purge mailbox.
PHI_RETENTION_DAYS=30

# --- Site URL (used by sitemap, canonical, OG, hreflang) ---
# In dev, leave as http://localhost:3000.
# In production, set to https://www.eminenthospice.com (or final canonical domain).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
